---
const currentPath = Astro.url.pathname;

const categories = [
  { slug: 'on-leadership', name: 'On Leadership' },
  { slug: 'on-war', name: 'On War' },
  { slug: 'on-dealing-with-people', name: 'On Dealing With People' },
  { slug: 'thoughts', name: 'Thoughts' },
  { slug: 'quotes', name: 'Quotes' },
];
---
<aside class="sidebar">
  <ul class="sidebar-links">
    <li><a href="/" class={currentPath === '/' ? 'active' : ''}>Home</a></li>
    <li><a href="/about/" class={currentPath.startsWith('/about') ? 'active' : ''}>About</a></li>
  </ul>
  <hr class="sidebar-divider" />
  <nav>
    <ul>
      {categories.map(({ slug, name }) => (
        <li>
          <a
            href={`/${slug}/`}
            class={currentPath.startsWith(`/${slug}`) ? 'active' : ''}
          >
            {name}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>
