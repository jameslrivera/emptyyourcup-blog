---
interface Props {
  title: string;
  description: string;
  date: Date;
  href: string;
}

const { title, description, date, href } = Astro.props;

const formatted = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<article class="post-card">
  <h3><a href={href}>{title}</a></h3>
  <span class="post-date">{formatted}</span>
  <p>{description}</p>
</article>
